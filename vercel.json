{
    "version": 2,
    "builds": [
      {
        "src": "server/index.js",
        "use": "@vercel/node"
      }
    ],
    "routes": [
      {
        "src": "/api/vpn",
        "dest": "/server/routes/vpn.js"
      },
      {
        "src": "/(.*)",
        "dest": "/server/index.js"
      }
    ]
  }
  